<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <!-- 뒤로가기 버튼 -->
    <Button
        android:id="@+id/buttonBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← 뒤로가기"
        android:textSize="16sp"
        android:backgroundTint="@color/oliveyoung_green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- 총 금액 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/totalCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/buttonBack"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/textTotalPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="총 금액: ₩0"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/oliveyoung_green"
            android:padding="20dp"
            android:gravity="center" />
    </androidx.cardview.widget.CardView>

    <!-- 상태 메시지 -->
    <TextView
        android:id="@+id/textStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="바코드를 스캔하여\n상품을 담아주세요"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/totalCard"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp" />

    <!-- 장바구니 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintBottom_toTopOf="@id/buttonLayout"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- 버튼 레이아웃 -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/imageQr"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="8dp">

        <!-- 바코드 스캔 -->
        <androidx.cardview.widget.CardView
            android:layout_width="190dp"
            android:layout_height="190dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_margin="5dp">

            <Button
                android:id="@+id/buttonScan"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📷\n\n바코드\n스캔"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="@color/text_secondary" />
        </androidx.cardview.widget.CardView>

        <!-- 결제하기 -->
        <androidx.cardview.widget.CardView
            android:layout_width="190dp"
            android:layout_height="190dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_margin="5dp">

            <Button
                android:id="@+id/buttonPay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="💳\n\n결제\n하기"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="@color/oliveyoung_green" />
        </androidx.cardview.widget.CardView>

        <!-- 결제 완료 -->
        <androidx.cardview.widget.CardView
            android:layout_width="190dp"
            android:layout_height="190dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_margin="5dp">

            <Button
                android:id="@+id/buttonPaymentDone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="✅\n\n결제\n완료"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="@color/oliveyoung_pink" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- QR 코드 -->
    <ImageView
        android:id="@+id/imageQr"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:contentDescription="결제 QR 코드"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
